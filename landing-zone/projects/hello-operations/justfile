set shell := ["bash", "-euo", "pipefail", "-c"]

# Inputs from propeller (PROPELLER_INPUT_* env vars).
# env("VAR") without a default fails if the variable is not set (required).
# env("VAR", "fallback") provides a default (optional).

region := env("AWS_REGION")
security_ou_id := env("PROPELLER_INPUT_security_ou_id")
optional_value := env("PROPELLER_INPUT_optional_value", "")

init:
    @echo "Input: security_ou_id={{ security_ou_id }}"
    @echo "Input: optional_value={{ optional_value }}"

plan:
    @echo "Would write SSM parameter /demo/hello-operations"

apply:
    aws ssm put-parameter \
        --name "/demo/hello-operations" \
        --type String \
        --value "Hello from operations (OU: {{ security_ou_id }})" \
        --overwrite \
        --region "{{ region }}"
    @echo "Writing outputs..."
    echo '{"message": "Hello from operations", "color": "blue"}' > .propeller-outputs.json

destroy:
    aws ssm delete-parameter \
        --name "/demo/hello-operations" \
        --region "{{ region }}" || true

outputs:
    @cat .propeller-outputs.json 2>/dev/null || echo '{}'
