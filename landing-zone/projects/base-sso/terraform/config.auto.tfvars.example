# base-sso — IAM Identity Center baseline configuration
# Copy this file to config.auto.tfvars and fill in your values.

# AWS region (must match the IAM Identity Center home region).
region = "eu-central-2"

# Set to true if Identity Center is fed by an external IdP (e.g. Entra ID
# via SCIM). When true, the IdentityOperators group is looked up by name
# instead of being created locally.
external_idp = false

# Name of the IdentityOperators group in the identity store.
# When external_idp = true, a group with this exact name must exist in the
# external IdP (e.g. synced via SCIM from Entra ID).
# identity_operators_group_name = "aws-identity-operators"

# Session duration for all permission sets (ISO 8601).
# session_duration = "PT1H"

# Per-permission-set relay state overrides. All keys are optional.
# Defaults (computed from var.region):
#   readonly, poweruser, admin  -> https://<region>.console.aws.amazon.com
#   identity_operator           -> https://<region>.console.aws.amazon.com/singlesignon/
#
# relay_states = {
#   admin             = "https://eu-central-2.console.aws.amazon.com/cloudtrail/"
#   identity_operator = "https://eu-central-2.console.aws.amazon.com/singlesignon/"
# }

# ── Tags ──────────────────────────────────────────────────────────────────────

# Tags applied to all resources created by this project.
# tags = {
#   "acme:custom-tag" = "value"
# }
