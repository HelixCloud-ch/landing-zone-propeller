import "../../../shared/recipes/terraform.just"

plan: tf-plan
apply: tf-apply
destroy: tf-destroy

# ── Sleep/Wake modes ──────────────────────────────────────────────────────────
# Supported modes:
#   stop      - RDS stop/start (fast, keeps data, 7-day auto-restart limit)
#   snapshot  - Targeted destroy with final snapshot, recreate on wake
#   destroy   - Full terraform destroy/apply (inherited from shared recipe)

sleep-default: sleep-stop
wake-default: wake-stop

sleep-stop: tf-init
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ _tf_dir }}
    DB_ID=$(terraform output -raw db_instance_identifier 2>/dev/null || true)
    [[ -z "$DB_ID" ]] && echo "ERROR: no db_instance_identifier in state." && exit 1
    STATUS=$(aws rds describe-db-instances --db-instance-identifier "$DB_ID" --region "$AWS_REGION" --query 'DBInstances[0].DBInstanceStatus' --output text 2>/dev/null || echo "not-found")
    case "$STATUS" in
      stopped)   echo "Already stopped." && exit 0 ;;
      not-found) echo "ERROR: DB '$DB_ID' not found." && exit 1 ;;
    esac
    aws rds stop-db-instance --db-instance-identifier "$DB_ID" --region "$AWS_REGION"

wake-stop: tf-init
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ _tf_dir }}
    DB_ID=$(terraform output -raw db_instance_identifier)
    STATUS=$(aws rds describe-db-instances --db-instance-identifier "$DB_ID" --region "$AWS_REGION" --query 'DBInstances[0].DBInstanceStatus' --output text)
    case "$STATUS" in
      available) echo "Already running." && exit 0 ;;
      stopping)  echo "DB is stopping, waiting..." && aws rds wait db-instance-stopped --db-instance-identifier "$DB_ID" --region "$AWS_REGION" ;;
    esac
    aws rds start-db-instance --db-instance-identifier "$DB_ID" --region "$AWS_REGION"
    aws rds wait db-instance-available --db-instance-identifier "$DB_ID" --region "$AWS_REGION"

sleep-snapshot: tf-init
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ _tf_dir }}
    DB_ID=$(terraform output -raw db_instance_identifier)
    if ! aws rds describe-db-instances --db-instance-identifier "$DB_ID" --region "$AWS_REGION" &>/dev/null; then
      echo "DB '$DB_ID' not found. Already sleeping." && exit 0
    fi
    DEL_PROT=$(aws rds describe-db-instances --db-instance-identifier "$DB_ID" --region "$AWS_REGION" --query 'DBInstances[0].DeletionProtection' --output text)
    [[ "$DEL_PROT" == "True" ]] && echo "ERROR: deletion_protection is enabled. Disable in project config." && exit 1
    # Update state so targeted destroy uses our final_snapshot_identifier
    terraform apply -auto-approve $(just _propeller-vars) \
      -var "skip_final_snapshot=false" \
      -var "final_snapshot_identifier={{ _sleep_snapshot_id }}" \
      -var "apply_immediately=true"
    # Targeted destroy: only the DB instance (preserves SG, subnet group, secrets)
    terraform apply -destroy \
      -target='module.rds_oracle.aws_db_instance.this' \
      -auto-approve $(just _propeller-vars) \
      -var "skip_final_snapshot=false" \
      -var "final_snapshot_identifier={{ _sleep_snapshot_id }}" \
      -var "apply_immediately=true"

wake-snapshot: tf-init
    #!/usr/bin/env bash
    set -euo pipefail
    cd {{ _tf_dir }}
    terraform apply -auto-approve $(just _propeller-vars) \
      -var "snapshot_identifier={{ _sleep_snapshot_id }}"
    DB_ID=$(terraform output -raw db_instance_identifier)
    aws rds wait db-instance-available --db-instance-identifier "$DB_ID" --region "$AWS_REGION"
    aws rds delete-db-snapshot --db-snapshot-identifier "{{ _sleep_snapshot_id }}" --region "$AWS_REGION" 2>/dev/null || true
