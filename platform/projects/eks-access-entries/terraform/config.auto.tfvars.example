region = "eu-central-2"

# cluster_name is injected by the pipeline from the eks-cluster project output.
# Do NOT set it here.

# ── IAM Identity Center home region ──────────────────────────────────────────
# Must match the region where IAM Identity Center is homed for your organization.
# The AWSReservedSSO_* role path prefix includes this region (except us-east-1).
sso_region = "eu-central-2"

# ── SSO-discovered access entries ─────────────────────────────────────────────
# The default map (ReadOnly/PowerUser/Admin → View/Edit/ClusterAdmin) matches the
# base-sso project. Override to rename keys, use different permission set names,
# or change the access policies. Add entries for any extra permission sets.
# Multiple policies can be listed per entry — permissions are additive.
#
# Note: AWS does not support custom EKS access policies. For custom Kubernetes
# RBAC, specify kubernetesGroups on the access entry (not managed here) and
# create ClusterRole/ClusterRoleBinding objects in the cluster.
#
# sso_access_entries = {
#   readonly = {
#     permission_set_name = "ReadOnly"
#     policy_arns         = ["arn:aws:eks::aws:cluster-access-policy/AmazonEKSViewPolicy"]
#   }
#   poweruser = {
#     permission_set_name = "PowerUser"
#     policy_arns         = ["arn:aws:eks::aws:cluster-access-policy/AmazonEKSEditPolicy"]
#   }
#   admin = {
#     permission_set_name = "Admin"
#     policy_arns         = ["arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy"]
#   }
# }

# ── Direct ARN access entries ─────────────────────────────────────────────────
# For IAM roles or users whose ARN is already known and that are not created by
# IAM Identity Center. Deploy runner roles belong in eks-cluster via
# additional_admin_role_names, not here.
#
# Typical uses:
#   - A break-glass IAM user that needs read-only cluster access for emergencies
#   - An external monitoring or security tool (e.g. a SIEM agent role) that
#     needs view access independently of SSO
#   - A cross-account role from a central operations account
#
# direct_access_entries = {
#   break_glass = {
#     principal_arn = "arn:aws:iam::123456789012:user/break-glass-operator"
#     policy_arns   = ["arn:aws:eks::aws:cluster-access-policy/AmazonEKSViewPolicy"]
#   }
# }
