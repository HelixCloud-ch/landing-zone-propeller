# Propeller consumer recipes, auto-updated on every `just pull`.
# Import this from your root justfile:
#   import? '.propeller/consumer/justfile'
#
# The root justfile should define the `pull` recipe (bootstrap/update).
# All other recipes are provided here and stay in sync with the framework.
#
# Build artifacts are written under dist/<pipeline>/ — the landing-zone
# pipeline uses dist/landing-zone/, each platform uses dist/<platform>/.
# Requirements: uv, yq, jq, aws-cli

bundle_s3_bucket := env("PROPELLER_BUNDLE_BUCKET", "")
lambda_function := env("PROPELLER_LAMBDA_ARN", "")

# Repo-wide framework version pin.

propeller_version := shell("cat .propeller-version 2>/dev/null || yq '.propeller.version' landing-zone/propeller.overrides.yaml")

# ── Landing zone ──────────────────────────────────────────────────────────────

# Resolve the landing-zone pipeline (framework base + consumer overrides)
resolve:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p dist/landing-zone
    resolve_args=()
    if [[ -n "${ONLY:-}" ]]; then
        resolve_args+=(--highlight "$ONLY")
    fi
    if [[ -n "${DEPLOY_ACTION:-}" ]]; then
        resolve_args+=(--action "$DEPLOY_ACTION")
    fi
    # Custom propeller.yaml (direct mode) or framework base + overrides
    if [[ -f "landing-zone/propeller.yaml" ]]; then
        BASE="landing-zone/propeller.yaml"
    else
        BASE=".propeller/landing-zone/propeller.yaml"
        resolve_args+=(--overrides "landing-zone/propeller.overrides.yaml")
    fi
    uv run --project .propeller/engine propeller-resolve \
        --base "$BASE" \
        --version "{{ propeller_version }}" \
        --output dist/landing-zone/pipeline.lock.yaml \
        --propeller-dir .propeller/landing-zone \
        ${resolve_args[@]+"${resolve_args[@]}"}

# Validate the resolved landing-zone pipeline
validate:
    uv run --project .propeller/engine propeller-validate \
        --pipeline dist/landing-zone/pipeline.lock.yaml \
        --no-check-sources

# Bundle the landing-zone pipeline into a deployable zip
bundle:
    uv run --project .propeller/engine propeller-bundle \
        --pipeline dist/landing-zone/pipeline.lock.yaml \
        --propeller-dir .propeller/landing-zone \
        --overlay-dir landing-zone/projects \
        --output dist/landing-zone/bundle.zip

# Upload the landing-zone bundle to S3
upload: (_upload "landing-zone")

# Invoke the autopilot Lambda to run the landing-zone pipeline
trigger: (_trigger "landing-zone")

# Build the landing zone locally (resolve + validate + bundle)
build: resolve validate bundle

# Deploy the landing zone to AWS (build + upload + trigger)
deploy: build upload trigger

# ── Platforms ─────────────────────────────────────────────────────────────────

# Resolve a platform pipeline (consumer-authored, framework platform projects)
platform-resolve name:
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p dist/{{ name }}
    resolve_args=()
    if [[ -n "${ONLY:-}" ]]; then
        resolve_args+=(--highlight "$ONLY")
    elif [[ -n "${SLEEP_PRESET:-}" ]]; then
        resolve_args+=(--highlight "$SLEEP_PRESET")
    fi
    if [[ -n "${DEPLOY_ACTION:-}" ]]; then
        resolve_args+=(--action "$DEPLOY_ACTION")
    fi
    uv run --project .propeller/engine propeller-resolve \
        --base platforms/{{ name }}/pipeline.yaml \
        --version "{{ propeller_version }}" \
        --output dist/{{ name }}/pipeline.lock.yaml \
        --propeller-dir .propeller/platform \
        ${resolve_args[@]+"${resolve_args[@]}"}

# Validate a resolved platform pipeline
platform-validate name:
    uv run --project .propeller/engine propeller-validate \
        --pipeline dist/{{ name }}/pipeline.lock.yaml \
        --no-check-sources

# Bundle a platform pipeline into a deployable zip
platform-bundle name:
    #!/usr/bin/env bash
    set -euo pipefail
    overlay_args=()
    if [[ -d "platforms/{{ name }}/projects" ]]; then
        overlay_args+=(--overlay-dir "platforms/{{ name }}/projects")
    fi
    uv run --project .propeller/engine propeller-bundle \
        --pipeline "dist/{{ name }}/pipeline.lock.yaml" \
        --propeller-dir .propeller/platform \
        ${overlay_args[@]+"${overlay_args[@]}"} \
        --output "dist/{{ name }}/bundle.zip"

# Build a platform locally (resolve + validate + bundle)
platform-build name: (platform-resolve name) (platform-validate name) (platform-bundle name)

# Deploy a platform to AWS (build + upload + trigger)
platform-deploy name: (platform-build name) (_upload name) (_trigger name)

# Deploy every platform under platforms/
platform-deploy-all:
    #!/usr/bin/env bash
    set -euo pipefail
    shopt -s nullglob
    for d in platforms/*/; do
        name=$(basename "$d")
        echo "=== Deploying platform: ${name} ==="
        just platform-deploy "$name"
    done

# ── Shared (private) ──────────────────────────────────────────────────────────

# Upload a built bundle to S3 under a unique SHA-based key
_upload pipeline:
    #!/usr/bin/env bash
    set -euo pipefail
    GIT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    aws s3 cp "dist/{{ pipeline }}/bundle.zip" "s3://{{ bundle_s3_bucket }}/bundles/{{ pipeline }}/${GIT_SHA}.zip"
    echo "Uploaded: s3://{{ bundle_s3_bucket }}/bundles/{{ pipeline }}/${GIT_SHA}.zip"

# Invoke the autopilot Lambda for a built pipeline
_trigger pipeline:
    #!/usr/bin/env bash
    set -euo pipefail
    DEPLOY_ACTION="${DEPLOY_ACTION:-apply}"
    DEPLOY_MODE="${DEPLOY_MODE:-autopilot}"
    FUNCTION_ARN="{{ lambda_function }}:\$LATEST"
    GIT_SHA=$(git rev-parse --short HEAD 2>/dev/null || echo "unknown")
    BUNDLE_URI="s3://{{ bundle_s3_bucket }}/bundles/{{ pipeline }}/${GIT_SHA}.zip"
    TIMESTAMP=$(date -u +%Y%m%dT%H%M%S)
    EXEC_NAME="{{ pipeline }}__${DEPLOY_ACTION}__${GIT_SHA}__${TIMESTAMP}"
    ONLY_ARGS=""
    if [[ -n "${ONLY:-}" ]]; then
        ONLY_ARGS=$(jq -n --arg only "$ONLY" '{only: ($only | split(",") | map(gsub("^\\s+|\\s+$"; "")))}')
    fi
    DESTROY_ALL_ARG=""
    if [[ "${DESTROY_ALL:-}" == "true" ]]; then
        DESTROY_ALL_ARG='{"destroy_all": true}'
    fi
    SLEEP_PRESET_ARG=""
    if [[ -n "${SLEEP_PRESET:-}" ]]; then
        SLEEP_PRESET_ARG=$(jq -n --arg p "$SLEEP_PRESET" '{sleep_preset: $p}')
    fi
    PAYLOAD=$(jq -n \
        --argjson pipeline "$(jq '{namespace: .namespace, propeller_version: .propeller_version, consumer_tags: .consumer_tags, stages: .stages, sleep_presets: (.sleep_presets // null)}' dist/{{ pipeline }}/pipeline.lock.json)" \
        --arg bundle_s3_uri "$BUNDLE_URI" \
        --arg deploy_action "$DEPLOY_ACTION" \
        --arg deploy_mode "$DEPLOY_MODE" \
        --arg git_sha "$GIT_SHA" \
        --argjson only_filter "${ONLY_ARGS:-null}" \
        --argjson destroy_all_filter "${DESTROY_ALL_ARG:-null}" \
        --argjson sleep_preset_filter "${SLEEP_PRESET_ARG:-null}" \
        '{pipeline: $pipeline, bundle_s3_uri: $bundle_s3_uri, deploy_action: $deploy_action, deploy_mode: $deploy_mode, git_sha: $git_sha} + (if $only_filter then $only_filter else {} end) + (if $destroy_all_filter then $destroy_all_filter else {} end) + (if $sleep_preset_filter then $sleep_preset_filter else {} end)')
    echo "Invoking ${FUNCTION_ARN} ({{ pipeline }}, ${DEPLOY_ACTION})${ONLY:+ [only: $ONLY]}..."
    echo "Execution: ${EXEC_NAME}"
    aws lambda invoke \
        --function-name "$FUNCTION_ARN" \
        --invocation-type Event \
        --durable-execution-name "$EXEC_NAME" \
        --payload "$PAYLOAD" \
        --cli-binary-format raw-in-base64-out \
        /dev/null
    echo "Triggered"

# Remove generated files
clean:
    rm -rf .propeller dist
