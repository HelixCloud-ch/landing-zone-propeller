# Propeller consumer recipes, auto-updated on every `just pull`.
# Import this from your root justfile:
#   import? '.propeller/consumer/justfile'
#
# The root justfile should define the `pull` recipe (bootstrap/update).
# All other recipes are provided here and stay in sync with the framework.

# Requirements: uv, yq, jq, aws-cli

bundle_s3_bucket := env("PROPELLER_BUNDLE_BUCKET", "")
lambda_function := env("PROPELLER_LAMBDA_ARN", "")

# Resolve the pipeline (merge base + overrides)
resolve:
    mkdir -p dist
    uv run --project .propeller/engine propeller-resolve \
        --base .propeller/landing-zone/propeller.yaml \
        --overrides landing-zone/propeller.overrides.yaml \
        --output dist/pipeline.lock.yaml \
        --propeller-dir .propeller/landing-zone

# Validate the resolved pipeline
validate:
    uv run --project .propeller/engine propeller-validate \
        --pipeline dist/pipeline.lock.yaml \
        --no-check-sources

# Bundle everything into a single deployable zip
bundle:
    uv run --project .propeller/engine propeller-bundle \
        --pipeline dist/pipeline.lock.yaml \
        --propeller-dir .propeller/landing-zone \
        --overlay-dir landing-zone/projects \
        --output dist/bundle.zip

# Upload the bundle to S3
upload:
    aws s3 cp dist/bundle.zip "s3://{{bundle_s3_bucket}}/bundle.zip"

# Invoke the autopilot Lambda to run the pipeline
trigger:
    #!/usr/bin/env bash
    set -euo pipefail
    DEPLOY_ACTION="${DEPLOY_ACTION:-apply}"
    FUNCTION_ARN="{{lambda_function}}:\$LATEST"
    ONLY_ARGS=""
    if [[ -n "${ONLY:-}" ]]; then
        ONLY_ARGS=$(jq -n --arg only "$ONLY" '{only: [$only]}')
    fi
    PAYLOAD=$(jq -n \
        --argjson pipeline "$(jq '{namespace: .namespace, stages: .stages}' dist/pipeline.lock.json)" \
        --arg bundle_s3_uri "s3://{{bundle_s3_bucket}}/bundle.zip" \
        --arg deploy_action "$DEPLOY_ACTION" \
        --argjson only_filter "${ONLY_ARGS:-null}" \
        '{pipeline: $pipeline, bundle_s3_uri: $bundle_s3_uri, deploy_action: $deploy_action} + (if $only_filter then $only_filter else {} end)')
    echo "Invoking ${FUNCTION_ARN} (${DEPLOY_ACTION})${ONLY:+ [only: $ONLY]}..."
    aws lambda invoke \
        --function-name "$FUNCTION_ARN" \
        --invocation-type Event \
        --payload "$PAYLOAD" \
        --cli-binary-format raw-in-base64-out \
        /dev/null
    echo "Triggered"

# Build locally (resolve + validate + bundle)
build: resolve validate bundle

# Deploy to AWS (build + upload + trigger)
deploy: build upload trigger

# Remove generated files
clean:
    rm -rf .propeller dist
