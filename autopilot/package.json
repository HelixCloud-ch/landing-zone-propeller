    "@aws-sdk/client-codebuild": "3.1086.0",
    "@aws-sdk/client-lambda": "3.1087.0",
    "@aws-sdk/client-s3": "3.1086.0",
    "@aws-sdk/client-ssm": "3.1086.0",
    "@aws-sdk/client-sts": "3.1086.0",
    "@aws/durable-execution-sdk-js": "^2.1.0"
  },
  "devDependencies": {
    "@aws/durable-execution-sdk-js-testing": "^1.1.3",
    "@biomejs/biome": "^2.5.0",
    "tsdown": "^0.22.7",
    "typescript": "~6.0.3",
    "vitest": "^4.1.0"
  }
